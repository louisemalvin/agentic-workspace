# Ghostty baseline for persistent agent workspaces.

font-family = JetBrains Mono
font-size = 13

window-padding-x = 10
window-padding-y = 8
window-padding-balance = true

background = #101216
foreground = #e7eaf0
selection-background = #334155
selection-foreground = #ffffff
cursor-color = #f8fafc

palette = 0=#0f172a
palette = 1=#ef4444
palette = 2=#22c55e
palette = 3=#eab308
palette = 4=#60a5fa
palette = 5=#c084fc
palette = 6=#2dd4bf
palette = 7=#e5e7eb
palette = 8=#475569
palette = 9=#f87171
palette = 10=#4ade80
palette = 11=#facc15
palette = 12=#93c5fd
palette = 13=#d8b4fe
palette = 14=#5eead4
palette = 15=#f8fafc

copy-on-select = clipboard
confirm-close-surface = false

# Keep split/navigation chords available for tmux and remote sessions.
keybind = ctrl+a=unbind
keybind = ctrl+shift+d=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+enter=unbind
keybind = ctrl+shift+left=unbind
keybind = ctrl+shift+right=unbind
keybind = ctrl+shift+up=unbind
keybind = ctrl+shift+down=unbind
