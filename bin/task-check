#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
usage: task-check <task-file>

Checks whether a .tasks artifact has the sections needed for handoff-ready work.
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -ne 1 ]]; then
  usage >&2
  exit 2
fi

task_file="$1"

if [[ ! -f "$task_file" ]]; then
  printf 'missing task file: %s\n' "$task_file" >&2
  exit 1
fi

required_sections=(
  "Goal"
  "Context"
  "Decisions"
  "Acceptance Criteria"
  "Implementation Plan"
  "Handoff Contract"
  "Verification Plan"
  "Status"
  "Handoff Notes"
)

missing=0
empty=0

section_body() {
  local file="$1"
  local section="$2"
  awk -v section="$section" '
    $0 == "## " section { in_section = 1; next }
    in_section && /^## / { exit }
    in_section { print }
  ' "$file"
}

has_content() {
  sed '/^[[:space:]]*$/d' |
    sed '/^[[:space:]]*-[[:space:]]*$/d' |
    grep -q '[^[:space:]]'
}

for section in "${required_sections[@]}"; do
  if ! grep -qx "## $section" "$task_file"; then
    printf 'missing section: %s\n' "$section"
    missing=$((missing + 1))
    continue
  fi

  if ! section_body "$task_file" "$section" | has_content; then
    printf 'empty section: %s\n' "$section"
    empty=$((empty + 1))
  fi
done

if [[ "$missing" -eq 0 && "$empty" -eq 0 ]]; then
  printf 'task artifact ready: %s\n' "$task_file"
  exit 0
fi

printf 'task artifact incomplete: %s (%d missing, %d empty)\n' "$task_file" "$missing" "$empty" >&2
exit 1
