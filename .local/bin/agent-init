#!/usr/bin/env bash
set -euo pipefail

target="${1:-AGENTS.md}"

if [[ -e "$target" ]]; then
  printf '%s already exists; leaving it unchanged.\n' "$target"
  exit 0
fi

project_name="$(basename "$PWD")"

cat >"$target" <<EOF
# ${project_name} Agent Guide

## Project

Describe what this project is and who it serves.

## Stack

- Runtime:
- Framework:
- Package manager:
- Database:
- Deployment:

## Commands

- Install:
- Dev:
- Test:
- Lint:
- Typecheck:
- Build:

## Architecture

List the important directories and what they own.

## Workflow

- Keep task-specific planning in .tasks/*.md, not in this file.
- Update the active task artifact before handing work to another harness.
- Verify behavior against acceptance criteria before calling work done.

## Known Traps

- Add repeated agent mistakes here after they happen.
EOF

printf 'created %s\n' "$target"
