#!/usr/bin/env bash
set -euo pipefail

target="${1:-AGENTS.md}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
template="$script_dir/../../templates/AGENTS.md"

if [[ -e "$target" ]]; then
  printf '%s already exists; leaving it unchanged.\n' "$target"
  exit 0
fi

project_name="$(basename "$PWD")"

if [[ ! -f "$template" ]]; then
  printf 'missing template: %s\n' "$template" >&2
  exit 1
fi

awk -v project_name="$project_name" '
  { gsub(/\{\{PROJECT_NAME\}\}/, project_name); print }
' "$template" >"$target"

printf 'created %s\n' "$target"
